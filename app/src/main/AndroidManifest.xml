<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Tema2">
        
        <activity 
            android:name=".SplashScreen"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity 
            android:name=".MainActivity"
            android:label="Dashboard"
            android:theme="@style/Tema1"
            android:exported="false" />

        <activity 
            android:name=".DataMahasiswa"
            android:label="Data Mahasiswa"
            android:theme="@style/Tema1"
            android:exported="false"
            android:parentActivityName=".MainActivity"/>
            
        <activity 
            android:name=".Informasi"
            android:label="Tentang Aplikasi"
            android:theme="@style/Tema1"
            android:exported="false"
            android:parentActivityName=".MainActivity"/>

        <activity 
            android:name=".InputData"
            android:label="Tambah Data Baru"
            android:theme="@style/Tema1"
            android:exported="false"
            android:parentActivityName=".DataMahasiswa"/>

        <activity android:name=".UpdateData" 
            android:label="Update Data Mahasiswa"
            android:theme="@style/Tema1"
            android:exported="false"
            android:parentActivityName=".DataMahasiswa"/>

        <activity 
            android:name=".DetailData" 
            android:label="Detail Informasi" 
            android:theme="@style/Tema1"
            android:exported="false"
            android:parentActivityName=".DataMahasiswa"/>
        
    </application>

</manifest>